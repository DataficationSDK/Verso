<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="icon" type="image/png" href="icon.png" />
    <link rel="stylesheet" href="app.css?v=4" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />

    <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js"></script>
    <script src="js/monaco-interop.js?v=2"></script>
    <script src="js/dashboard-interop.js"></script>
    <script src="js/panel-resize-interop.js"></script>
    <script src="js/file-download-interop.js"></script>
    <script src="js/save-dialog-interop.js"></script>
    <script src="js/mermaid-interop.js"></script>
    <script src="js/recovery-interop.js"></script>
    <script src="js/cell-interact-interop.js"></script>
    <div id="verso-reconnect-overlay" style="display:none">
        <div class="verso-reconnect-box">
            <div class="verso-spinner verso-spinner--large"></div>
            <h3 id="verso-reconnect-title">Reconnecting...</h3>
            <p id="verso-reconnect-message">Your session is still active. Attempting to reconnect.</p>
            <button id="verso-reconnect-reload" style="display:none" onclick="location.reload()">Reload page</button>
        </div>
    </div>

    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        (() => {
            const overlay = document.getElementById('verso-reconnect-overlay');
            const title = document.getElementById('verso-reconnect-title');
            const message = document.getElementById('verso-reconnect-message');
            const reloadBtn = document.getElementById('verso-reconnect-reload');
            const pageLoadTime = Date.now();
            let isDisconnected = false;
            let disconnectTimer = null;

            function recoverAndReload() {
                title.textContent = 'Recovering your session...';
                message.textContent = 'Reloading to restore your notebook.';
                reloadBtn.style.display = 'none';
                overlay.style.display = 'flex';

                // Pass file path via URL so the server can recover during
                // component initialization — no interactive circuit needed.
                var state = window.versoRecovery.getState();
                var url = '/';
                if (state && state.filePath) {
                    url = '/?recover=' + encodeURIComponent(state.filePath);
                }
                setTimeout(() => { window.location.href = url; }, 1000);
            }

            Blazor.start({
                circuit: {
                    reconnectionOptions: {
                        maxRetries: 30,
                        retryIntervalMilliseconds: (previousAttempts) =>
                            previousAttempts < 10 ? 1000
                            : previousAttempts < 20 ? 3000
                            : 5000
                    },
                    reconnectionHandler: {
                        onConnectionDown(options, error) {
                            isDisconnected = true;

                            // Don't show the overlay for connection failures during
                            // initial page load (e.g. recovery reload where the server
                            // needs a moment to clean up the old circuit).
                            if (Date.now() - pageLoadTime < 10000) return;

                            overlay.style.display = 'flex';
                            title.textContent = 'Reconnecting...';
                            message.textContent = 'Your session is still active. Attempting to reconnect.';
                            reloadBtn.style.display = 'none';

                            // Foreground fallback: if the tab stays visible, reload after 2 min
                            if (!disconnectTimer) {
                                disconnectTimer = setTimeout(recoverAndReload, 120000);
                            }
                        },
                        onConnectionUp() {
                            isDisconnected = false;
                            overlay.style.display = 'none';
                            if (disconnectTimer) {
                                clearTimeout(disconnectTimer);
                                disconnectTimer = null;
                            }
                        }
                    }
                }
            });

            // When the user returns to a backgrounded tab, browsers will have
            // throttled/suspended setTimeout, so the foreground timer won't have
            // fired. Detect tab re-activation and reload immediately if disconnected.
            document.addEventListener('visibilitychange', () => {
                if (document.visibilityState === 'visible' && isDisconnected
                    && Date.now() - pageLoadTime > 10000) {
                    recoverAndReload();
                }
            });
        })();
    </script>
</body>
</html>
